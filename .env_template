# Copy this file to .env and fill in your actual values

# Google Gemini API Key (required for LLM and embeddings)
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Alternative: You can also use GEMINI_API_KEY
# GEMINI_API_KEY=your-google-api-key-here

# AWS Configuration (optional - for email notifications via SES)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=careconnect-documents
SES_SENDER_EMAIL=noreply@example.com

# Model Configuration (optional - defaults provided)
# GEMINI_MODEL=gemini-3.1-flash-lite
# EMBEDDING_MODEL=gemini-embedding-001
# TEMPERATURE=0.2

# ChromaDB Configuration (optional - defaults provided)
# CHROMA_COLLECTION_NAME=medical_protocols
# CHUNK_SIZE=700
# CHUNK_OVERLAP=100

# Database Configuration (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///data/db/app.db
